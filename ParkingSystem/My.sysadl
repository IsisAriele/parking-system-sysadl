Model SysADLModel ; package SysADL.types { value type Int { } value type Boolean { } value type String { } value type Void { } value type Real { } enum SpotState { Free , Occupied } enum AvailabilityStatus { Available , Full } enum GateCommand { Open , Close } } package ParkingSystemPorts { import SysADL.types ; port def VehicleDetectedOPT { flow out Boolean } port def VehicleDetectedIPT { flow in Boolean } port def SpotStateOPT { flow out SpotState } port def SpotStateIPT { flow in SpotState } port def GateCommandOPT { flow out GateCommand } port def GateCommandIPT { flow in GateCommand } port def AvailabilityOPT { flow out AvailabilityStatus } port def AvailabilityIPT { flow in AvailabilityStatus } } package ParkingSystemConnectors { import ParkingSystemPorts ; import SysADL.types ; connector def DetectVehicleCN { participants : ~ source : VehicleDetectedOPT ; ~ destination : VehicleDetectedIPT ; flows : Boolean from source to destination } connector def ReportSpotStateCN { participants : ~ source : SpotStateOPT ; ~ destination : SpotStateIPT ; flows : SpotState from source to destination } connector def SendGateCommandCN { participants : ~ source : GateCommandOPT ; ~ destionation : GateCommandIPT ; flows : GateCommand from source to destionation } connector def SendAvailabilityCN { participants : ~ source : AvailabilityOPT ; ~ destination : AvailabilityIPT ; flows : AvailabilityStatus from source to destination } } package ParkingControllerCP { import SysADL.types ; import ParkingSystemConnectors ; import ParkingSystemPorts ;
	component def ParkingControlSystem { configuration { components : entrySensor : EntryVehicleSensorCP { using ports : detected : VehicleDetectedOPT ; } spot1 : ParkingSpotSensorCP { using ports : state : SpotStateOPT ; } spot2 : ParkingSpotSensorCP { using ports : state : SpotStateOPT ; } controller : ParkingControllerCP { using ports : vehicle : VehicleDetectedIPT ; spotState1 : SpotStateIPT ; spotState2 : SpotStateIPT ; gateCommand : GateCommandOPT ; status : AvailabilityOPT ; } gate : GateActuatorCP { using ports : command : GateCommandIPT ; } panel : StatusPanelCP { using ports : availability : AvailabilityIPT ; } connectors : vehicleDetection : DetectVehicleCN bindings detected = vehicle ; spotReport1 : ReportSpotStateCN bindings state = spotState1 ; gateControl : SendGateCommandCN bindings gateCommand = command ; statusDisplay : SendAvailabilityCN bindings status = availability ; } }
	component def EntryVehicleSensorCP { ports : detected : VehicleDetectedOPT ; }
	component def ParkingSpotSensorCP { ports : state : SpotStateOPT ; }
	component def ParkingControllerCP { ports : vehicle : VehicleDetectedIPT ; spotState1 : SpotStateIPT ; spotState2 : SpotStateIPT ; gateCommand : GateCommandOPT ; status : AvailabilityOPT ; }
	component def GateActuatorCP { ports : command : GateCommandIPT ; }
	component def StatusPanelCP { ports : availability : AvailabilityIPT ; } activity def MonitorParkingSpacesAC ( spotState1 : SpotState ) ( spotState2 : SpotState ) : ( availability : AvailabilityStatus ) { body { actions : CheckAvailabilityAN : CheckAvailabilityAN { using pins : spotState1 : SpotState ; spotState2 : SpotState ; } delegate spotState1 to spotState1 delegate spotState2 to spotState2 delegate availability to CheckAvailabilityAN } } activity def ControlParkingAccessAC ( vehicleDetected : Boolean ) ( availability : AvailabilityStatus ) : ( gateCommand : GateCommand ) { body { actions : CommandGateAN : CommandGateAN { using pins : vehicleDetected : Boolean ; availability : AvailabilityStatus ; } delegate vehicleDetected to vehicleDetected delegate availability to availability delegate gateCommand to CommandGateAN } } activity def UpdateDisplayAC ( availability : AvailabilityStatus ) : ( status : AvailabilityStatus ) { body { actions : DisplayStatusAN : DisplayStatusAN { using pins : availability : AvailabilityStatus ; } delegate availability to availability delegate status to DisplayStatusAN } } action def CheckAvailabilityAN ( spotState1 : SpotState , spotState2 : SpotState ) : AvailabilityStatus { constraint : post-condition CheckAvailabilityEQ delegate CheckAvailabilityAN to availability delegate spotState1 to spotState1 delegate spotState2 to spotState2 } action def CommandGateAN ( vehicleDetected : Boolean , availability : AvailabilityStatus ) : GateCommand { constraint : post-condition CommandGateEQ delegate vehicleDetected to vehicleDetected delegate CommandGateAN to gateCommand delegate availability to availability } action def DisplayStatusAN ( availability : AvailabilityStatus ) : AvailabilityStatus { } constraint CheckAvailabilityEQ ( spotState1 : SpotState , spotState2 : SpotState ) : ( availability : AvailabilityStatus ) { } constraint CommandGateEQ ( vehicleDetected : Boolean , availability : AvailabilityStatus ) : ( gateCommand : GateCommand ) { } activity def DetectVehicleAtEntryAC ( sensorSignal : Boolean ) : ( vehicleDetected : Boolean ) { body { actions : DetectVehicleAN : DetectVehicleAN { using pins : sensorSignal : Boolean ; } delegate vehicleDetected to DetectVehicleAN delegate sensorSignal to sensorSignal } } action def DetectVehicleAN ( sensorSignal : Boolean ) : Boolean { } activity def MonitorSpotStateAC ( spotSensorSignal : SpotState ) : ( spotState : SpotState ) { body { actions : ReadSpotStateAN : ReadSpotStateAN { using pins : spotSensorSignal : SpotState ; } delegate spotSensorSignal to spotSensorSignal delegate spotState to ReadSpotStateAN } } action def ReadSpotStateAN ( spotSensorSignal : SpotState ) : SpotState { } } Requirement ControlParkingAccessFR ( 1 ) { text = "The system must control the entry of vehicles into the parking lot according to parking space availability." Requirement DetectVehicleAtEntryFR ( 2 ) { text = "The system must detect the presence of a vehicle at the parking entrance." } Requirement MonitorParkingSpacesFR ( 3 ) { text = "The system must monitor whether each parking space is free or occupied." } Requirement VerifyAvailabilityFR ( 5 ) { text = "The system must verify whether there is at least one free parking space before allowing vehicle entry." } Requirement DisplayStatusFR ( 8 ) { text = "The system must display to the driver whether parking spaces are available or the parking lot is full." } } Requirement ScalabilityNFR ( 10 ) { text = "The architecture must support the addition of parking space sensors without requiring changes to the main control logic." } Requirement IntegrateHardwareFR ( 9 ) { text = "The system must integrate parking space sensors, an entrance vehicle sensor, a gate actuator and a status display panel." } Requirement UpdateOccupancyFR ( 4 ) { text = "The system must update the number of free and occupied parking spaces whenever a parking space changes its state." derive ControlParkingAccessFR.MonitorParkingSpacesFR ; } Requirement OpenGateFR ( 6 ) { text = "The system must open the gate when a vehicle is detected and at least one parking space is available." } Requirement KeepGateClosedFR ( 7 ) { text = "The system must keep the gate closed when no parking space is available." }